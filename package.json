{
  "name": "forkzero",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=renderer --filter=desktop",
    "dev": "turbo run dev",
    "dev:desktop": "node scripts/dev.mjs",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@effect/platform": "^0.96.0",
      "@effect/platform-node": "^0.106.0",
      "@effect/rpc": "^0.75.0",
      "@types/node": "^22.15.3",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "effect": "^3.21.0",
      "eslint": "^9.39.1",
      "prettier": "^3.7.4",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "turbo": "^2.9.7",
      "typescript": "5.9.2"
    }
  },
  "overrides": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "^0.75.0",
    "effect": "^3.21.0"
  }
}
