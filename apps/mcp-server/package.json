{
  "name": "@memoize/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/bin.ts",
  "bin": {
    "memoize-mcp": "./src/bin.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "dev": "bun src/bin.ts",
    "build:bin": "bun build --compile --outfile dist/memoize-mcp src/bin.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@memoize/index": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "effect": "catalog:",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
